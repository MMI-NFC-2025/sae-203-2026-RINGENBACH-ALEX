---
import Mail from "../assets/icons/mail.svg";
import Location from "../assets/icons/position.svg";
import Phone from "../assets/icons/call.svg";
import Facebook from "../assets/icons/facebook.svg";
import Instagram from "../assets/icons/instagram.svg";
---

<footer class="bg-[#ebe6da] text-neutral-700">
    <div
        class="px-6 py-12 flex flex-col gap-10 lg:max-w-6xl lg:mx-auto lg:grid lg:grid-cols-3 lg:gap-12"
    >
        <nav>
            <h3 class="font-semibold text-lg mb-4 text-neutral-900">
                Navigation
            </h3>

            <ul class="flex flex-col gap-2 text-sm">
                <li>
                    <a href="/" class="hover:text-[#d97706] transition">
                        Accueil
                    </a>
                </li>

                <li>
                    <a href="/festival" class="hover:text-[#d97706] transition">
                        Le Festival
                    </a>
                </li>

                <li>
                    <a
                        href="/programme"
                        class="hover:text-[#d97706] transition"
                    >
                        Programme
                    </a>
                </li>

                <li>
                    <a href="/artistes" class="hover:text-[#d97706] transition">
                        Artistes
                    </a>
                </li>

                <li>
                    <a href="/infos" class="hover:text-[#d97706] transition">
                        Infos Pratiques
                    </a>
                </li>

                <li>
                    <a href="/contact" class="hover:text-[#d97706] transition">
                        Contact
                    </a>
                </li>
            </ul>
        </nav>

        <div>
            <h3 class="font-semibold text-lg mb-4 text-neutral-900">Contact</h3>

            <address class="not-italic flex flex-col gap-4 text-sm">
                <p class="flex items-start gap-3">
                    <Location class="w-5 h-5 text-[#d97706] shrink-0" />
                    <span>
                        Place Saint-Martin <br />
                        25200 Montbéliard
                    </span>
                </p>

                <p class="flex items-center gap-3">
                    <Mail class="w-5 h-5 text-[#d97706] shrink-0" />
                    <a
                        href="mailto:contact@fanfacomtoise.fr"
                        class="hover:text-[#d97706] transition"
                    >
                        contact@fanfacomtoise.fr
                    </a>
                </p>

                <p class="flex items-center gap-3">
                    <Phone class="w-5 h-5 text-[#d97706] shrink-0" />
                    <a
                        href="tel:0381123456"
                        class="hover:text-[#d97706] transition"
                    >
                        03 81 12 34 56
                    </a>
                </p>
            </address>
        </div>

        <div>
            <h3 class="font-semibold text-lg mb-2 text-neutral-900">
                Suivez-nous
            </h3>

            <p class="text-sm mb-4">
                Restez informés de l'actualité du festival
            </p>

            <ul class="flex gap-4">
                <li>
                    <a
                        href="#"
                        aria-label="Facebook"
                        class="w-10 h-10 flex items-center justify-center rounded-full bg-[#c6d68b] hover:bg-[#b7c977] transition"
                    >
                        <Facebook class="w-5 h-5 text-white" />
                    </a>
                </li>

                <li>
                    <a
                        href="#"
                        aria-label="Instagram"
                        class="w-10 h-10 flex items-center justify-center rounded-full bg-[#c6d68b] hover:bg-[#b7c977] transition"
                    >
                        <Instagram class="w-5 h-5 text-white" />
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="bg-[#c6d68b] text-center text-sm py-4 text-neutral-800">
        © 2025 La Fanfà'Comtoise - Tous droits réservés
    </div>
</footer>
