---
import { getFileUrl } from "../../backend/backend.mjs";

const { scene } = Astro.props;

const photo = scene.photo ? getFileUrl(scene, scene.photo) : null;
---

<a
    href={`/Scenes/${scene.id}`}
    class="block bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition"
>
    {photo && <img src={photo} class="w-full h-48 object-cover" />}

    <div class="p-6">
        <h2 class="text-xl font-bold mb-2">
            {scene.nom}
        </h2>

        <p class="text-sm text-neutral-500 mb-2">
            {scene.localisation}
        </p>

        <p class="text-sm text-neutral-600">
            {scene.capacite}
        </p>

        <p class="text-sm text-neutral-500 mt-2">
            {scene.description}
        </p>
    </div>
</a>
