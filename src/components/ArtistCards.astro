---
import PbImage from "./PbImage.astro";

const { artiste } = Astro.props;

const date = new Date(artiste.date).toLocaleDateString("fr-FR", {
    day: "numeric",
    month: "long",
    year: "numeric",
});

const hour = new Date(artiste.date).toLocaleTimeString("fr-FR", {
    hour: "2-digit",
    minute: "2-digit",
});
---

<a
    href={`/Artistes/${artiste.id}`}
    class="block bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition"
>
    <div class="h-56 w-full bg-neutral-200">
        <PbImage
            record={artiste}
            recordImage="photo"
            alt={artiste.nom}
            class="h-full w-full object-cover"
        />
    </div>

    <div class="p-6">
        <h2 class="text-xl font-bold mb-2">
            {artiste.nom}
        </h2>

        <p class="text-sm text-neutral-600">
            {date} — {hour}
        </p>

        <p class="text-sm text-neutral-500">
            {artiste.expand?.scene?.nom}
        </p>
    </div>
</a>
