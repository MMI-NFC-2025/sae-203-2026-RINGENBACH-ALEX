---
import Logo from "../assets/icons/logo-du-site.svg";
---

<header class="fixed top-0 left-0 w-full bg-white z-50">
    <div
        class="flex items-center justify-between px-6 py-4 lg:max-w-6xl lg:mx-auto"
    >
        <div>
            <a href="/" aria-label="Accueil">
                <Logo class="h-10 w-auto" />
            </a>
        </div>

        <nav class="hidden lg:block">
            <ul class="flex items-center gap-8 text-sm font-medium">
                <li>
                    <a href="/Festival" class="hover:text-[#d97706] transition">
                        Le Festival
                    </a>
                </li>

                <li>
                    <a href="/Artistes" class="hover:text-[#d97706] transition">
                        Artistes
                    </a>
                </li>

                <li>
                    <a
                        href="/Programme"
                        class="hover:text-[#d97706] transition"
                    >
                        Programme
                    </a>
                </li>

                <li>
                    <a href="/Scenes" class="hover:text-[#d97706] transition">
                        Scènes
                    </a>
                </li>

                <li>
                    <a href="/Infos" class="hover:text-[#d97706] transition">
                        Infos pratiques
                    </a>
                </li>

                <li>
                    <a href="/Contact" class="hover:text-[#d97706] transition">
                        Contact
                    </a>
                </li>
            </ul>
        </nav>

        <div class="flex items-center gap-4 lg:hidden">
            <button
                id="menu-btn"
                aria-label="Menu"
                aria-controls="menu"
                aria-expanded="false"
                class="flex flex-col gap-1 z-50"
            >
                <span class="block w-6 h-0.5 bg-black"></span>
                <span class="block w-6 h-0.5 bg-black"></span>
                <span class="block w-6 h-0.5 bg-black"></span>
            </button>

            <nav
                id="menu"
                aria-hidden="true"
                class="fixed inset-0 bg-black text-white flex items-center justify-center hidden"
            >
                <button
                    id="close-menu"
                    aria-label="Fermer le menu"
                    class="absolute top-6 right-6 text-3xl"
                >
                    ✕
                </button>

                <ul class="flex flex-col gap-8 text-lg text-center">
                    <li><a href="/">Accueil</a></li>
                    <li><a href="/Festival">Le Festival</a></li>
                    <li><a href="/Artistes">Artistes</a></li>
                    <li><a href="/Programme">Programme</a></li>
                    <li><a href="/Scenes">Scènes</a></li>
                    <li><a href="/Infos">Infos pratiques</a></li>
                    <li><a href="/Contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </div>
</header>

<script>
    const menuBtn = document.getElementById("menu-btn");
    const closeBtn = document.getElementById("close-menu");
    const menu = document.getElementById("menu");

    function openMenu() {
        menu.classList.remove("hidden");
        menuBtn.setAttribute("aria-expanded", "true");
        menu.setAttribute("aria-hidden", "false");
    }

    function closeMenu() {
        menu.classList.add("hidden");
        menuBtn.setAttribute("aria-expanded", "false");
        menu.setAttribute("aria-hidden", "true");
    }

    menuBtn.addEventListener("click", openMenu);
    closeBtn.addEventListener("click", closeMenu);
</script>
