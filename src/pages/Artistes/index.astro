---
import Layout from "../../layouts/Layout.astro";
import PbImage from "../../components/PbImage.astro";
import {
    allArtistesByDate,
    allScenesByName,
} from "../../../backend/backend.mjs";

const artistes = await allArtistesByDate();
const scenes = await allScenesByName();

const genres = [
    ...new Set(artistes.map((artiste) => artiste.genre).filter(Boolean)),
];
const dates = [
    ...new Set(
        artistes
            .filter((artiste) => artiste.date)
            .map(
                (artiste) => new Date(artiste.date).toISOString().split("T")[0],
            ),
    ),
];
---

<Layout>
    <main class="bg-[#f6f4ef] text-neutral-900">
        <section class="bg-[#d97706] text-white py-20 text-center px-6">
            <h1 class="text-4xl font-bold mb-4">Les artistes</h1>
            <p class="max-w-xl mx-auto text-lg text-white/90">
                Découvrez les artistes présents au festival
            </p>
        </section>

        <section class="max-w-6xl mx-auto px-6 py-10">
            <div class="grid gap-4 md:grid-cols-3 mb-10">
                <select
                    id="genreFilter"
                    class="border border-neutral-300 rounded-lg px-4 py-3 bg-white"
                >
                    <option value="">Tous les genres</option>
                    {
                        genres.map((genre) => (
                            <option value={genre}>{genre}</option>
                        ))
                    }
                </select>

                <select
                    id="sceneFilter"
                    class="border border-neutral-300 rounded-lg px-4 py-3 bg-white"
                >
                    <option value="">Toutes les scènes</option>
                    {
                        scenes.map((scene) => (
                            <option value={scene.nom}>{scene.nom}</option>
                        ))
                    }
                </select>

                <select
                    id="dateFilter"
                    class="border border-neutral-300 rounded-lg px-4 py-3 bg-white"
                >
                    <option value="">Toutes les dates</option>
                    {dates.map((date) => <option value={date}>{date}</option>)}
                </select>
            </div>

            <div
                id="artistsGrid"
                class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3"
            >
                {
                    artistes.map((artiste) => (
                        <article
                            class="artist-card bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition"
                            data-genre={artiste.genre || ""}
                            data-scene={artiste.expand?.scene?.nom || ""}
                            data-date={
                                artiste.date
                                    ? new Date(artiste.date)
                                          .toISOString()
                                          .split("T")[0]
                                    : ""
                            }
                        >
                            <a href={`/Artistes/${artiste.id}`} class="block">
                                <div class="h-60 w-full bg-neutral-200">
                                    <PbImage
                                        record={artiste}
                                        recordImage="photo"
                                        alt={`${artiste.prenom || ""} ${artiste.nom}`}
                                        class="h-full w-full object-cover"
                                    />
                                </div>

                                <div class="p-6">
                                    <h2 class="text-xl font-bold mb-2">
                                        {artiste.prenom
                                            ? `${artiste.prenom} ${artiste.nom}`
                                            : artiste.nom}
                                    </h2>

                                    <p class="text-sm text-neutral-500 mb-2">
                                        {artiste.genre}
                                    </p>

                                    {artiste.date && (
                                        <p class="text-sm text-neutral-600">
                                            {new Date(
                                                artiste.date,
                                            ).toLocaleString("fr-FR", {
                                                day: "2-digit",
                                                month: "long",
                                                year: "numeric",
                                                hour: "2-digit",
                                                minute: "2-digit",
                                            })}
                                        </p>
                                    )}

                                    {artiste.expand?.scene && (
                                        <p class="text-sm text-neutral-500 mt-2">
                                            {artiste.expand.scene.nom}
                                        </p>
                                    )}
                                </div>
                            </a>
                        </article>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>

<script>
    const genreFilter = document.getElementById("genreFilter");
    const sceneFilter = document.getElementById("sceneFilter");
    const dateFilter = document.getElementById("dateFilter");
    const cards = document.querySelectorAll(".artist-card");

    function filterArtists() {
        const genre = genreFilter.value;
        const scene = sceneFilter.value;
        const date = dateFilter.value;

        cards.forEach((card) => {
            const cardGenre = card.dataset.genre || "";
            const cardScene = card.dataset.scene || "";
            const cardDate = card.dataset.date || "";

            let visible = true;

            if (genre && cardGenre !== genre) {
                visible = false;
            }

            if (scene && cardScene !== scene) {
                visible = false;
            }

            if (date && cardDate !== date) {
                visible = false;
            }

            card.style.display = visible ? "block" : "none";
        });
    }

    genreFilter.addEventListener("change", filterArtists);
    sceneFilter.addEventListener("change", filterArtists);
    dateFilter.addEventListener("change", filterArtists);
</script>
