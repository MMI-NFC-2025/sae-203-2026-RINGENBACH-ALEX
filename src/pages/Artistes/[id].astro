---
import Layout from "../../layouts/Layout.astro";
import { oneArtisteById } from "../../../backend/backend.mjs";

const { id } = Astro.params;

const artiste = await oneArtisteById(id);
---

<Layout>
    <main class="bg-[#f6f4ef] text-neutral-900">
        <section class="bg-[#d97706] text-white py-20 text-center px-6">
            <h1 class="text-4xl font-bold mb-4">
                {artiste.prenom}
                {artiste.nom}
            </h1>

            <p class="text-lg text-white/90">
                {artiste.genre}
            </p>
        </section>

        <section class="max-w-4xl mx-auto px-6 py-16">
            <div
                class="bg-white rounded-xl p-8 shadow-sm border border-neutral-200"
            >
                <p class="text-neutral-600 mb-6">
                    {artiste.description}
                </p>

                <p class="text-sm text-neutral-500">
                    Date : {new Date(artiste.date).toLocaleString()}
                </p>

                {
                    artiste.expand?.scene && (
                        <p class="text-sm text-neutral-500 mt-2">
                            Scène : {artiste.expand.scene.nom}
                        </p>
                    )
                }
            </div>
        </section>
    </main>
</Layout>
