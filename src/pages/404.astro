---
import "../styles/global.css";
---

<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>404 – Page introuvable</title>
    </head>

    <body
        class="min-h-screen flex items-center justify-center bg-[#f6f4ef] text-neutral-900 px-6"
    >
        <main class="text-center max-w-xl">
            <h1 class="text-[120px] font-bold text-[#d97706] leading-none mb-6">
                404
            </h1>

            <h2 class="text-3xl font-bold mb-4">Page introuvable</h2>

            <p class="text-neutral-600 mb-10">
                Oups… La page que vous cherchez n'existe pas ou a été déplacée.
            </p>

            <a
                href="/"
                class="inline-block bg-[#d97706] text-white px-8 py-3 rounded-full font-semibold hover:bg-orange-500 transition"
            >
                Retour à l'accueil
            </a>
        </main>
    </body>
</html>
