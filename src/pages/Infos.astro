---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="bg-[#f6f4ef] text-neutral-900">
        <section class="bg-[#d97706] text-white py-20 text-center px-6">
            <h1 class="text-4xl font-bold mb-4 lg:text-5xl">Infos Pratiques</h1>

            <p class="max-w-xl mx-auto text-lg text-white/90">
                Tout ce qu'il faut savoir pour profiter pleinement du festival
            </p>
        </section>

        <section class="max-w-5xl mx-auto px-6 py-16 lg:max-w-6xl">
            <h2 class="text-3xl font-bold mb-6">Tarifs</h2>

            <div class="grid gap-8 lg:grid-cols-2">
                <div
                    class="bg-white rounded-xl shadow-sm border border-neutral-200 p-8 text-center flex flex-col justify-center"
                >
                    <p class="text-2xl font-semibold text-[#d97706] mb-3">
                        Festival 100% Gratuit !
                    </p>

                    <p class="text-neutral-600">
                        L'entrée au festival est totalement gratuite et ouverte
                        à tous. Aucune réservation nécessaire.
                    </p>
                </div>

                <div class="bg-white rounded-xl p-6 border border-neutral-200">
                    <h3 class="font-semibold text-[#d97706] mb-3">
                        Restauration & Boissons
                    </h3>

                    <ul class="space-y-2 text-neutral-600">
                        <li>Caution gobelet réutilisable : 1€</li>
                        <li>Boissons : 2€ – 5€</li>
                        <li>Restauration locale : 5€ – 12€</li>
                        <li>Stands de producteurs bio et locaux</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="bg-white py-16">
            <div class="max-w-5xl mx-auto px-6 lg:max-w-6xl">
                <h2 class="text-3xl font-bold mb-8">Hébergements</h2>

                <div class="grid md:grid-cols-2 gap-8 lg:gap-10">
                    <div class="bg-[#f6f4ef] p-6 rounded-xl">
                        <h3 class="font-semibold mb-4 text-[#d97706]">
                            Hôtels
                        </h3>

                        <ul class="space-y-3 text-neutral-700">
                            <li>
                                <strong>Hôtel de la Balance</strong><br />
                                40 Rue de Belfort, Montbéliard<br />
                                À 5 min à pied du festival
                            </li>

                            <li>
                                <strong>Ibis Montbéliard</strong><br />
                                2 Rue Georges Pompidou<br />
                                À 10 min à pied du festival
                            </li>

                            <li>
                                <strong>B&B Hôtel</strong><br />
                                ZAC du Pied des Gouttes<br />
                                À 15 min en bus
                            </li>
                        </ul>
                    </div>

                    <div class="bg-[#f6f4ef] p-6 rounded-xl">
                        <h3 class="font-semibold mb-4 text-[#d97706]">
                            Campings
                        </h3>

                        <ul class="space-y-3 text-neutral-700">
                            <li>
                                <strong>Camping du Près-la-Rose</strong><br />
                                Avenue du Général Leclerc<br />
                                À 20 min à pied du festival
                            </li>

                            <li>
                                <strong>Aire de camping-cars</strong><br />
                                Place du Champ de Foire<br />
                                Gratuite, à 15 min du festival
                            </li>
                        </ul>
                    </div>
                </div>

                <p class="mt-6 text-sm text-neutral-600">
                    Pensez à réserver tôt, les hébergements se remplissent vite
                    !
                </p>
            </div>
        </section>

        <section class="max-w-5xl mx-auto px-6 py-16 lg:max-w-6xl">
            <h2 class="text-3xl font-bold mb-8">Accès & Transport</h2>

            <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
                <div class="bg-white p-6 rounded-xl border border-neutral-200">
                    <h3 class="font-semibold text-[#d97706] mb-3">En train</h3>

                    <p class="text-neutral-600 text-sm">
                        Gare de Montbéliard à 15 min à pied du centre-ville.
                    </p>

                    <ul class="mt-3 text-sm text-neutral-600 space-y-1">
                        <li>Paris : 2h30</li>
                        <li>Lyon : 3h</li>
                        <li>Besançon : 45 min</li>
                    </ul>
                </div>

                <div class="bg-white p-6 rounded-xl border border-neutral-200">
                    <h3 class="font-semibold text-[#d97706] mb-3">
                        En voiture
                    </h3>

                    <p class="text-neutral-600 text-sm">
                        Accès par l'A36 (sortie Montbéliard Centre)
                    </p>

                    <ul class="mt-3 text-sm text-neutral-600 space-y-1">
                        <li>Parking Champ de Foire – 500 places</li>
                        <li>Parking Gare – 300 places</li>
                        <li>Parking Halles – 200 places</li>
                    </ul>
                </div>

                <div class="bg-white p-6 rounded-xl border border-neutral-200">
                    <h3 class="font-semibold text-[#d97706] mb-3">
                        Transports doux
                    </h3>

                    <ul class="text-sm text-neutral-600 space-y-2">
                        <li>Parkings vélos sécurisés</li>
                        <li>Bus lignes 1, 2 et 3</li>
                        <li>Stations Vélocité à proximité</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="bg-[#ebe6da] py-16 px-6">
            <div class="max-w-4xl mx-auto lg:max-w-6xl">
                <h2 class="text-3xl font-bold text-center mb-10">
                    Questions fréquentes
                </h2>

                <div
                    class="space-y-4 lg:grid lg:grid-cols-2 lg:gap-6 lg:space-y-0"
                >
                    <div
                        class="faq-item bg-white rounded-xl border border-neutral-200"
                    >
                        <button
                            class="faq-question w-full flex justify-between items-center p-5 font-medium"
                        >
                            Le festival est-il vraiment gratuit ?
                            <span class="faq-icon text-xl">+</span>
                        </button>
                        <div
                            class="faq-answer hidden px-5 pb-5 text-neutral-600"
                        >
                            Oui, l'entrée au festival est totalement gratuite et
                            ouverte à tous.
                        </div>
                    </div>

                    <div
                        class="faq-item bg-white rounded-xl border border-neutral-200"
                    >
                        <button
                            class="faq-question w-full flex justify-between items-center p-5 font-medium"
                        >
                            Comment le festival respecte-t-il l'environnement ?
                            <span class="faq-icon text-xl">+</span>
                        </button>
                        <div
                            class="faq-answer hidden px-5 pb-5 text-neutral-600"
                        >
                            Le festival met en place des gobelets réutilisables,
                            favorise les producteurs locaux et encourage les
                            transports doux.
                        </div>
                    </div>

                    <div
                        class="faq-item bg-white rounded-xl border border-neutral-200"
                    >
                        <button
                            class="faq-question w-full flex justify-between items-center p-5 font-medium"
                        >
                            Peut-on venir avec des enfants ?
                            <span class="faq-icon text-xl">+</span>
                        </button>
                        <div
                            class="faq-answer hidden px-5 pb-5 text-neutral-600"
                        >
                            Oui, le festival est familial et accessible à tous
                            les publics.
                        </div>
                    </div>

                    <div
                        class="faq-item bg-white rounded-xl border border-neutral-200"
                    >
                        <button
                            class="faq-question w-full flex justify-between items-center p-5 font-medium"
                        >
                            Où peut-on se restaurer ?
                            <span class="faq-icon text-xl">+</span>
                        </button>
                        <div
                            class="faq-answer hidden px-5 pb-5 text-neutral-600"
                        >
                            Plusieurs stands de restauration locale et de
                            producteurs bio sont présents sur le festival.
                        </div>
                    </div>

                    <div
                        class="faq-item bg-white rounded-xl border border-neutral-200"
                    >
                        <button
                            class="faq-question w-full flex justify-between items-center p-5 font-medium"
                        >
                            Le festival est-il accessible aux personnes à
                            mobilité réduite ?
                            <span class="faq-icon text-xl">+</span>
                        </button>
                        <div
                            class="faq-answer hidden px-5 pb-5 text-neutral-600"
                        >
                            Oui, les espaces du festival sont accessibles aux
                            personnes à mobilité réduite.
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-[#d97706] text-white py-16 text-center px-6">
            <h2 class="text-3xl font-bold mb-4">Une question ?</h2>

            <p class="mb-6">
                Vous ne trouvez pas la réponse à votre question ? N'hésitez pas
                à nous contacter !
            </p>

            <a
                href="/contact"
                class="bg-white text-black px-8 py-3 rounded-full font-semibold"
            >
                Nous contacter
            </a>
        </section>
    </main>
</Layout>

<script>
    const questions = document.querySelectorAll(".faq-question");

    questions.forEach((question) => {
        question.addEventListener("click", () => {
            const answer = question.nextElementSibling;
            const icon = question.querySelector(".faq-icon");

            answer.classList.toggle("hidden");

            if (answer.classList.contains("hidden")) {
                icon.textContent = "+";
            } else {
                icon.textContent = "−";
            }
        });
    });
</script>
