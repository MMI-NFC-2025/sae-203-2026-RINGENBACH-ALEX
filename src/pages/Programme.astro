---
import Layout from "../layouts/Layout.astro";
import ArtistCard from "../components/ArtistCards.astro";
import { allArtistesProgramme } from "../../backend/backend.mjs";
const title = "Programme - Festival de Jazz de Montbéliard";

const artistes = await allArtistesProgramme();

const scenes = [...new Set(artistes.map((a) => a.expand?.scene?.nom))];
const genres = [...new Set(artistes.map((a) => a.genre))];
---

<Layout title={title}>
    <main class="bg-[#f6f4ef] text-neutral-900">
        <section class="bg-orange-500 text-white py-20 text-center px-6">
            <h1 class="text-4xl font-bold mb-4">Programme</h1>

            <p class="max-w-xl mx-auto text-lg text-white/90">
                Découvrez tous les concerts du festival.
            </p>
        </section>

        <section class="max-w-6xl mx-auto px-6 py-10">
            <div class="grid md:grid-cols-3 gap-4">
                <select id="genreFilter" class="border rounded-lg px-4 py-2">
                    <option value="">Tous les genres</option>

                    {
                        genres.map((genre) => (
                            <option value={genre}>{genre}</option>
                        ))
                    }
                </select>

                <select id="sceneFilter" class="border rounded-lg px-4 py-2">
                    <option value="">Toutes les scènes</option>

                    {
                        scenes.map((scene) => (
                            <option value={scene}>{scene}</option>
                        ))
                    }
                </select>

                <select id="dateFilter" class="border rounded-lg px-4 py-2">
                    <option value="">Toutes les dates</option>

                    {
                        [
                            ...new Set(
                                artistes.map((a) => a.date.split(" ")[0]),
                            ),
                        ].map((date) => <option value={date}>{date}</option>)
                    }
                </select>
            </div>
        </section>

        <section class="max-w-6xl mx-auto px-6 pb-20">
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    artistes.map((artiste) => (
                        <div
                            class="artist-card"
                            data-genre={artiste.genre}
                            data-scene={artiste.expand?.scene?.nom}
                            data-date={artiste.date.split(" ")[0]}
                        >
                            <ArtistCard artiste={artiste} />
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="bg-orange-400 px-6 py-14 text-center text-white">
            <h2 class="mb-4 text-3xl font-bold">Préparez votre venue</h2>

            <p class="mx-auto mb-8 max-w-xl text-sm">
                Téléchargez le programme complet et consultez toutes les
                informations pratiques pour profiter pleinement du festival.
            </p>
            <div
                class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
            >
                <a
                    href="/programme.pdf"
                    download
                    class="rounded-full bg-white px-8 py-3 font-semibold text-black shadow"
                >
                    Télécharger le programme
                </a>
            </div>
        </section>
    </main>
</Layout>

<script>
    const genreFilter = document.getElementById("genreFilter");
    const sceneFilter = document.getElementById("sceneFilter");
    const dateFilter = document.getElementById("dateFilter");

    const cards = document.querySelectorAll(".artist-card");

    function filterArtists() {
        const genre = genreFilter.value;
        const scene = sceneFilter.value;
        const date = dateFilter.value;

        cards.forEach((card) => {
            const cardGenre = card.dataset.genre;
            const cardScene = card.dataset.scene;
            const cardDate = card.dataset.date;

            let visible = true;

            if (genre && cardGenre !== genre) visible = false;
            if (scene && cardScene !== scene) visible = false;
            if (date && cardDate !== date) visible = false;

            card.style.display = visible ? "block" : "none";
        });
    }

    genreFilter.addEventListener("change", filterArtists);
    sceneFilter.addEventListener("change", filterArtists);
    dateFilter.addEventListener("change", filterArtists);
</script>
