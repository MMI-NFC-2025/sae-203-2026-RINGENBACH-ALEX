---
import Layout from "../layouts/Layout.astro";
const title = "Connexion - Festival de Jazz de Montbéliard";
---

<Layout title={title}>
    <main
        class="bg-[#f6f4ef] min-h-screen flex items-center justify-center px-6"
    >
        <div
            class="w-full max-w-md bg-white p-8 rounded-xl shadow border border-neutral-200"
        >
            <h1 class="text-3xl font-bold text-center mb-8">
                Connexion / Inscription
            </h1>
            <div class="flex mb-6 border-b">
                <button
                    id="loginTab"
                    type="button"
                    class="flex-1 py-2 font-semibold border-b-2 border-orange-500"
                >
                    Connexion
                </button>

                <button
                    id="registerTab"
                    type="button"
                    class="flex-1 py-2 font-semibold text-neutral-500 border-b-2 border-transparent"
                >
                    Inscription
                </button>
            </div>
            <form id="loginForm" class="space-y-4">
                <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <input
                    type="password"
                    name="password"
                    placeholder="Mot de passe"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <button
                    type="submit"
                    class="w-full bg-orange-500 text-white py-3 rounded-full font-semibold"
                >
                    Se connecter
                </button>
            </form>
            <form id="registerForm" class="space-y-4 hidden">
                <input
                    type="text"
                    name="name"
                    placeholder="Nom"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <input
                    type="password"
                    name="password"
                    placeholder="Mot de passe"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <p class="text-xs text-gray-500">
                    Le mot de passe doit contenir au moins 8 caractères
                </p>
                <input
                    type="password"
                    name="passwordConfirm"
                    placeholder="Confirmer mot de passe"
                    required
                    class="w-full border border-neutral-300 rounded-lg px-4 py-3"
                />
                <button
                    type="submit"
                    class="w-full bg-green-600 text-white py-3 rounded-full font-semibold"
                >
                    Créer un compte
                </button>
            </form>

            <p id="message" class="text-center text-sm mt-4 text-red-500"></p>
        </div>
    </main>

    <script type="module">
        import { Userauth, addNewUser } from "../../backend/backend.mjs";

        const loginTab = document.getElementById("loginTab");
        const registerTab = document.getElementById("registerTab");

        const loginForm = document.getElementById("loginForm");
        const registerForm = document.getElementById("registerForm");

        const message = document.getElementById("message");

        /* Switch tabs */

        loginTab.addEventListener("click", () => {
            loginForm.classList.remove("hidden");
            registerForm.classList.add("hidden");

            loginTab.classList.add("border-[#d97706]");
            loginTab.classList.remove("border-transparent");

            registerTab.classList.remove("border-[#d97706]");
            registerTab.classList.add("border-transparent");

            registerTab.classList.add("text-neutral-500");
            loginTab.classList.remove("text-neutral-500");
        });

        registerTab.addEventListener("click", () => {
            registerForm.classList.remove("hidden");
            loginForm.classList.add("hidden");

            registerTab.classList.add("border-[#d97706]");
            registerTab.classList.remove("border-transparent");

            loginTab.classList.remove("border-[#d97706]");
            loginTab.classList.add("border-transparent");

            loginTab.classList.add("text-neutral-500");
            registerTab.classList.remove("text-neutral-500");
        });

        /* Login */

        loginForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            try {
                await Userauth(loginForm.email.value, loginForm.password.value);

                message.textContent = "Connexion réussie";

                window.location.href = "/";
            } catch {
                message.textContent = "Email ou mot de passe incorrect";
            }
        });

        /* Register */

        registerForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            if (
                registerForm.password.value !==
                registerForm.passwordConfirm.value
            ) {
                message.textContent = "Les mots de passe ne correspondent pas";
                return;
            }

            try {
                await addNewUser({
                    name: registerForm.name.value,
                    email: registerForm.email.value,
                    password: registerForm.password.value,
                    passwordConfirm: registerForm.passwordConfirm.value,
                });

                message.textContent = "Compte créé avec succès";

                registerForm.reset();
            } catch {
                message.textContent = "Erreur lors de l'inscription";
            }
        });
    </script>
</Layout>
