---
import Layout from "../layouts/Layout.astro";
import HeroImage from "../assets/img/hero-du-site.avif";
import Date from "../assets/icons/date-orange.svg";
import DateWhite from "../assets/icons/date-blanc.svg";
import Location from "../assets/icons/position.svg";
import Moloco from "../assets/icons/moloco.svg";
import Montbeliard from "../assets/icons/Montbeliard.svg";
import PMontbeliard from "../assets/icons/Pays_de_Montbeliard.svg";
import Airbnb from "../assets/icons/airbnb.svg";
import CA from "../assets/icons/Credit-Agricole-Logo.svg";
import Doubs from "../assets/icons/doubs.svg";
import Comte from "../assets/icons/comte.svg";
import Feuille from "../assets/icons/feuille.svg";
import Gratuit from "../assets/icons/gratuit.svg";
import Ticket from "../assets/icons/ticket.svg";
---

<Layout>
    <main class="bg-neutral-50 text-neutral-900">
        <section class="relative h-[90vh] min-h-150 w-full overflow-hidden">
            <div class="absolute inset-0">
                <img
                    src={HeroImage.src}
                    alt="Festival La Fanfà'Comtoise"
                    class="h-full w-full object-cover"
                />
            </div>
            <div class="absolute inset-0 bg-black/40"></div>

            <div
                class="relative z-10 flex h-full flex-col items-center justify-center px-6 text-center"
            >
                <h1
                    class="mb-6 max-w-xl text-4xl font-bold uppercase leading-tight text-white"
                >
                    Jazz, fanfares & musiques de rues
                </h1>

                <div class="mb-8 h-1 w-20 bg-orange-400"></div>
                <div class="mb-8 flex flex-col gap-4 sm:flex-row">
                    <div
                        class="flex items-center gap-3 rounded-xl bg-white px-5 py-4 shadow-md"
                    >
                        <Date class="w-5 h-5" />

                        <div class="text-left">
                            <p class="text-xs uppercase text-gray-400">Date</p>
                            <p class="text-lg font-semibold">27–29 juin 2025</p>
                        </div>
                    </div>

                    <div
                        class="flex items-center gap-3 rounded-xl bg-white px-5 py-4 shadow-md"
                    >
                        <Location class="w-5 h-5" />

                        <div class="text-left">
                            <p class="text-xs uppercase text-gray-400">Lieu</p>
                            <p class="text-lg font-semibold">Montbéliard</p>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col items-center gap-4">
                    <a
                        href="#"
                        class="flex items-center gap-2 rounded-full bg-orange-400 px-8 py-4 text-lg font-medium text-white shadow-lg transition hover:bg-orange-500"
                    >
                        <DateWhite class="w-5 h-5" />
                        Découvrir le programme →
                    </a>

                    <div class="flex gap-3">
                        <a
                            href="#"
                            class="flex items-center gap-2 rounded-full bg-yellow-300 px-6 py-3 font-semibold shadow hover:bg-yellow-400"
                        >
                            <Ticket class="text-black w-5 h-5" />
                            Billetterie
                        </a>

                        <a
                            href="#"
                            class="flex items-center gap-2 rounded-full bg-lime-300 px-6 py-3 font-semibold shadow hover:bg-lime-400"
                        >
                            <Gratuit class="w-5 h-5" />
                            Gratuit & Éco
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="px-6 py-14">
            <div class="mx-auto grid max-w-4xl gap-6 sm:grid-cols-2">
                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="mb-2 flex items-center gap-2">
                        <svg class="h-5 w-5"></svg>
                        <h3 class="font-semibold">6 Artistes</h3>
                    </div>
                    <p class="text-sm text-gray-500">
                        Jazz, fanfare et musiques de rue
                    </p>
                </div>

                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="mb-2 flex items-center gap-2">
                        <Feuille class="h-5 w-5" />
                        <h3 class="font-semibold">100% Éco</h3>
                    </div>
                    <p class="text-sm text-gray-500">
                        Festival écoresponsable et local
                    </p>
                </div>

                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="mb-2 flex items-center gap-2">
                        <svg class="h-5 w-5"></svg>
                        <h3 class="font-semibold">Gratuit</h3>
                    </div>
                    <p class="text-sm text-gray-500">
                        Ouvert et accessible à tous
                    </p>
                </div>

                <div
                    class="rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="mb-2 flex items-center gap-2">
                        <svg class="h-5 w-5"></svg>
                        <h3 class="font-semibold">3 Scènes</h3>
                    </div>
                    <p class="text-sm text-gray-500">
                        Dans le centre historique
                    </p>
                </div>
            </div>
        </section>

        <section class="bg-gray-100 px-6 py-14">
            <h2 class="mb-10 text-center text-3xl font-bold">
                Découvrez le festival
            </h2>

            <div class="mx-auto max-w-3xl space-y-4">
                <a
                    class="group flex items-center justify-between rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="flex items-start gap-4">
                        <svg class="mt-1 h-6 w-6"></svg>

                        <div>
                            <h3 class="font-semibold">Programme</h3>
                            <p class="text-sm text-gray-500">
                                Tous les concerts et horaires
                            </p>
                        </div>
                    </div>

                    <span class="text-xl transition group-hover:translate-x-1">
                        →
                    </span>
                </a>

                <a
                    class="group flex items-center justify-between rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="flex items-start gap-4">
                        <svg class="mt-1 h-6 w-6"></svg>

                        <div>
                            <h3 class="font-semibold">Artistes</h3>
                            <p class="text-sm text-gray-500">
                                Les artistes invités du festival
                            </p>
                        </div>
                    </div>

                    <span class="text-xl transition group-hover:translate-x-1">
                        →
                    </span>
                </a>

                <a
                    class="group flex items-center justify-between rounded-xl bg-white p-6 shadow-sm transition hover:shadow-md"
                >
                    <div class="flex items-start gap-4">
                        <svg class="mt-1 h-6 w-6"></svg>

                        <div>
                            <h3 class="font-semibold">Infos pratiques</h3>
                            <p class="text-sm text-gray-500">
                                Accès, transports et hébergement
                            </p>
                        </div>
                    </div>

                    <span class="text-xl transition group-hover:translate-x-1">
                        →
                    </span>
                </a>
            </div>
        </section>

        <section class="bg-gray-100 py-16 overflow-hidden">
            <h2 class="text-center text-3xl font-bold mb-10">
                Nos partenaires
            </h2>

            <div class="relative w-full overflow-hidden">
                <div
                    id="partners-track"
                    class="flex gap-12 w-max px-6 items-center"
                >
                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <Moloco class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <Montbeliard class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <PMontbeliard class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <Airbnb class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <CA class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <Doubs class="h-10 w-auto" />
                    </div>

                    <div
                        class="flex items-center justify-center w-40 h-20 bg-white rounded-lg shadow"
                    >
                        <Comte class="h-10 w-auto" />
                    </div>
                </div>
            </div>
        </section>
    </main>

    <section class="bg-orange-400 px-6 py-14 text-center text-white">
        <h2 class="mb-4 text-3xl font-bold">Préparez votre venue</h2>

        <p class="mx-auto mb-8 max-w-xl text-sm">
            Téléchargez le programme complet et consultez toutes les
            informations pratiques pour profiter pleinement du festival.
        </p>

        <div
            class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
        >
            <a
                class="rounded-full bg-white px-8 py-3 font-semibold text-black shadow"
            >
                Télécharger le programme
            </a>

            <a class="rounded-full border border-white px-8 py-3 font-semibold">
                Nous contacter
            </a>
        </div>
    </section>
</Layout>

<script>
    const track = document.getElementById("partners-track");

    track.innerHTML += track.innerHTML;

    let position = 0;
    const speed = 0.3;

    function animate() {
        position -= speed;
        track.style.transform = `translateX(${position}px)`;

        if (Math.abs(position) >= track.scrollWidth / 2) {
            position = 0;
        }

        requestAnimationFrame(animate);
    }

    animate();
</script>
